{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ultravox-voice-worker",
  "main": "index.ts",
  "compatibility_date": "2026-04-28",
  "compatibility_flags": ["nodejs_compat"],
  "ai": {
    "binding": "AI"
  },
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1
  },
  "routes": []
  // Secrets set via `wrangler secret put`:
  //   VOICE_HMAC_SECRET   — signs short-lived tokens issued by /api/voice/token
  //   DEV_BEARER_TOKEN    — static token for local curl smoke-tests only
  // Note: OPENROUTER_API_KEY was removed in v0.19.0 when LLM cleanup moved
  // client-side. You can `wrangler secret delete OPENROUTER_API_KEY` to clean
  // up the deployed worker.
}
