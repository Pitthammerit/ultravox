{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Ultravox",
  "version": "0.19.7",
  "identifier": "com.ultravox.dev",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "settings",
        "title": "Ultravox",
        "url": "index.html",
        "width": 480,
        "height": 720,
        "minWidth": 380,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "visible": true,
        "focus": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "dragDropEnabled": false
      },
      {
        "label": "pill",
        "title": "Ultravox Pill",
        "url": "index.html#/pill",
        "width": 424,
        "height": 172,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "focus": false,
        "acceptFirstMouse": true
      },
      {
        "label": "mode-overlay",
        "title": "Ultravox Mode",
        "url": "index.html#/mode-overlay",
        "width": 520,
        "height": 460,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Voice dictation companion for macOS",
    "longDescription": "Dictate into any focused text field with a global hotkey.",
    "macOS": {
      "signingIdentity": "Developer ID Application: Benjamin Kurtz Academy LLC (3VP6Q6ZXN8)",
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "12.0",
      "dmg": {
        "background": "dmg-assets/background.tiff",
        "windowSize": { "width": 660, "height": 540 },
        "appPosition": { "x": 180, "y": 170 },
        "applicationFolderPosition": { "x": 480, "y": 170 }
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/Pitthammerit/ultravox/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRGQkNCMDU0QjNDOEMzMDcKUldRSHc4aXpWTEM4VDFhUzI5U3pLUUozdm9nb1hyY25abVNyckRxZGRkUVpLQWZGN0RuWkdoUk4K"
    }
  }
}
