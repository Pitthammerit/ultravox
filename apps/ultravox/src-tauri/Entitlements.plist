<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required for getUserMedia({audio:true}) to work under Hardened Runtime. -->
    <key>com.apple.security.device.audio-input</key>
    <true/>

    <!-- Tauri's WKWebView and Rust runtime can JIT / load dynamic frameworks;
         these two keys avoid spurious hardened-runtime kills. -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>
    <key>com.apple.security.cs.allow-jit</key>
    <true/>
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow outbound HTTPS to the Cloudflare Voice Worker. -->
    <key>com.apple.security.network.client</key>
    <true/>
</dict>
</plist>
