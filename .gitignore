# Node / pnpm
node_modules/
.pnpm-store/
*.log
.DS_Store

# TypeScript / build
dist/
build/
*.tsbuildinfo

# Tauri / Rust (Cargo)
src-tauri/target/
target/
debug/
**/*.rs.bk
*.pdb
**/mutants.out*/

# Editor / IDE
.vscode/
.idea/
*.swp

# Env / secrets
.env
.env.local
.env.*.local

# Wrangler dev state
.wrangler/
**/worker-configuration.d.ts

# Lockfiles from non-pnpm package managers
package-lock.json

# OS
Thumbs.db

# Git worktrees
.worktrees/
.claude/worktrees/

# Apple Developer certificates / signing material — never commit these
certificate*/
*.p12
*.cer

# Shipping binaries — releases/ is tracked as a folder (with README) but
# the DMGs themselves are huge artifacts that belong in GitHub Releases,
# not the source tree.
*.dmg
*.app/
